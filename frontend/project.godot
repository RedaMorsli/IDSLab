; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="IDSLab"
run/main_scene="uid://bupx4raua7kg3"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="uid://b6kaagq0gn0py"

[autoload]

Server="*res://autoloads/websocket_server.tscn"
RequestStatus="*res://components/status/request_status.tscn"
ClusterManager="*res://autoloads/cluster_manager.tscn"
AppManager="*res://autoloads/app_manager.tscn"
AttackManager="*res://autoloads/attack_manager.tscn"
RerpositoryManager="*res://autoloads/repository_manager.tscn"
EventManager="*res://autoloads/event_manager.tscn"
Navigation="*res://autoloads/navigation.gd"
Setup="*res://autoloads/setup.gd"
RepositoryManager="*res://autoloads/repository_manager.tscn"
Dialog="*res://autoloads/dialog.tscn"
DatasetManager="*res://autoloads/dataset_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2

[global_group]

NavItems="Navigation items (buttons)"
NavDestinations=""
Navigation=""

[gui]

theme/custom_font="uid://cqkcdut5uvcrj"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.976471, 0.980392, 0.984314, 1)
